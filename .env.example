# Fruit Forecast — API Keys
# Copy this file to .env and fill in your keys.
# The app works without any keys (free APIs are used as fallbacks).

# Mapbox: more reliable geocoding (100k req/month free)
# https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=

# Spoonacular: recipe suggestions for in-season produce (150 req/day free)
# https://spoonacular.com/food-api/console
SPOONACULAR_KEY=

# PostHog: analytics dashboard (1M events/month free)
# https://app.posthog.com/signup
POSTHOG_KEY=

# Supabase: user profiles, auth, and data sync (free tier: 50k MAUs)
# https://supabase.com/dashboard — create a project, copy URL + anon key
# Note: anon keys are safe for client code (protected by Row Level Security)
SUPABASE_URL=
SUPABASE_ANON_KEY=
