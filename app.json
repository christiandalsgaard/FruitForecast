{
  "expo": {
    "name": "Fruit Forecast",
    "slug": "fruit-forecast",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fruitforecast",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#fdfcfb"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.fruitforecast",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Fruit Forecast uses your location to determine your climate zone and show which produce is in season near you.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#fdfcfb"
      },
      "package": "com.yourname.fruitforecast",
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"]
    },
    "platforms": ["ios", "android", "web"],
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Fruit Forecast uses your location to determine your climate zone and show which produce is in season near you."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
